{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    "/var/folders/2t/3kvx4xl52m1684g4dg_dn2580000gn/T/brandvertise-next/dev/types/**/*.ts",
    "/var/folders/2t/3kvx4xl52m1684g4dg_dn2580000gn/T/brandvertise-next/types/**/*.ts",
    "next-env.d.ts",
    "/private/var/folders/2t/3kvx4xl52m1684g4dg_dn2580000gn/T/brandvertise-next/types/**/*.ts",
    "/private/var/folders/2t/3kvx4xl52m1684g4dg_dn2580000gn/T/brandvertise-next/dev/types/**/*.ts",
    "/Users/ryhnsufi/.brandvertise-next/types/**/*.ts",
    "/Users/ryhnsufi/.brandvertise-next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
