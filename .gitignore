# Secrets — never commit
.env
.env.*
!.env.example

# Dependencies
node_modules/
frontend/node_modules/

# Build outputs
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/

# Local Next.js dist override (macOS dev only)
/Users/*/.brandvertise-next/

# Media outputs & logs
outputs/*.jpg
outputs/*.png
outputs/*.jpeg
logs/

# macOS resource forks & metadata
.DS_Store
**/.DS_Store
._*
**/._*

# Next.js local dev build cache (stored outside project on macOS)
*/.brandvertise-next/
frontend/Users/
frontend/private/
frontend/var/

# TypeScript
*.tsbuildinfo
frontend/next-env.d.ts
