# ─── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host/dbname
JWT_SECRET=replace-with-strong-random-secret
SESSION_SECRET=replace-with-strong-random-session-secret

# ─── Firebase ──────────────────────────────────────────
# Path to your Firebase Admin SDK service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or provide as a JSON string (for cloud deployments):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── Google Cloud Storage ──────────────────────────────
GCS_BUCKET_NAME=brandvertise-media
GCS_PROJECT_ID=your-gcp-project-id

# ─── OpenAI (text / JSON via callAI; images use Google below) ─
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google AI Studio (required for image generation) ─
GOOGLE_AI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Native Gemini image (Nano Banana Pro): https://ai.google.dev/gemini-api/docs/models/gemini-3-pro-image-preview
GOOGLE_NATIVE_IMAGE_MODEL=gemini-3-pro-image-preview
# Native image quality hint: speed | balanced | detail
# GOOGLE_NATIVE_IMAGE_QUALITY_PRESET=detail
# Optional Imagen fallback if native returns no image (set GOOGLE_IMAGE_IMAGEN_FALLBACK=false to disable)
# Tier picks default model when GOOGLE_IMAGEN_MODEL is unset: fast | standard | ultra
GOOGLE_IMAGEN_TIER=fast
# GOOGLE_IMAGEN_MODEL=imagen-4.0-generate-001
# GOOGLE_IMAGEN_IMAGE_SIZE=2K
# GOOGLE_IMAGEN_PERSON_GENERATION=allow_adult
# GOOGLE_IMAGE_IMAGEN_FALLBACK=false

# ─── Redis (for BullMQ) ───────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Razorpay ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ─── Buffer API ───────────────────────────────────────
BUFFER_ACCESS_TOKEN=1/xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Twilio (WhatsApp) ────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Email (Nodemailer — SMTP) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Brandvertise AI" <noreply@brandvertise.ai>

# ─── Credit Defaults ──────────────────────────────────
CREDITS_FREE=10
CREDITS_STANDARD=100
CREDITS_PREMIUM=500
CREDIT_COST_GENERATE=1
CREDIT_COST_REGENERATE=1
